# =============================================================================
# SuiWalrus Station - .gitignore
# =============================================================================
# ⚠️ このプロジェクトはブロックチェーンウォレットを扱います。
# ⚠️ 秘密鍵やAPIキーを絶対にコミットしないでください。
# ⚠️ 一度でもコミットすると、Git履歴に残り、資産盗難のリスクがあります。
# =============================================================================

# =============================================================================
# 🔴 最重要：秘密情報（絶対にコミット禁止）
# =============================================================================
# ⚠️ .env にはAPIキー、ウォレット情報、認証情報が含まれます。
# ⚠️ 一度コミットすると、git履歴から完全に削除するのは非常に困難です。
# ⚠️ 公開リポジトリにpushした瞬間、ボットに検出され資産を盗まれる可能性があります。
.env
.env.*
*.env
!.env.example

# =============================================================================
# 🔴 最重要：ウォレット・暗号鍵（コミット = 資産喪失の可能性）
# =============================================================================
# ⚠️ これらのファイルには秘密鍵やキーストアが含まれます。
# ⚠️ コミットした場合、ウォレット内の全資産が盗まれる可能性があります。
# ⚠️ Sui/Walrusの設定は ~/.sui/ や ~/.walrus/ に存在し、
#     プロジェクト内にコピーすること自体を禁止します。
.sui/
.walrus/
.config/walrus/
wallet/
wallets/
keystore/
*.keystore
*.key
*.pem
*.p12
*.pfx
*.jks
sui.keystore
sui_config/
client.yaml
# 秘密鍵のバックアップファイル
*.bak
*.backup
*secret*
*private*
*mnemonic*
*seed*

# =============================================================================
# 🟡 ログ・履歴（個人情報・操作履歴を含む可能性）
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# =============================================================================
# 🟡 ローカルデータ（ユーザー固有情報）
# =============================================================================
# コマンド実行履歴、ウォレットメタデータ等
data/
*.db
*.sqlite
*.sqlite3
history.json
wallet_metadata.json
settings.json

# =============================================================================
# Node.js
# =============================================================================
node_modules/
dist/
build/
.npm
.yarn/
.pnp.*

# =============================================================================
# Tauri（Rustバックエンド）
# =============================================================================
# target/ には大量のコンパイル済みバイナリが含まれます（数GB）
src-tauri/target/
src-tauri/.cargo/
target/
*.rs.bk

# =============================================================================
# Electron（将来対応用）
# =============================================================================
out/
release/
*.exe
*.app
*.dmg
*.deb
*.rpm
*.AppImage
*.snap

# =============================================================================
# キャッシュ・一時ファイル
# =============================================================================
.cache/
.parcel-cache/
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# =============================================================================
# OS依存ファイル
# =============================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.Trash-*

# =============================================================================
# エディタ・IDE
# =============================================================================
.vscode/
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# =============================================================================
# テスト・カバレッジ
# =============================================================================
coverage/
.nyc_output/
*.lcov

# =============================================================================
# CI/CD（GitHub Actions等）
# =============================================================================
# CI/CDの秘密情報（ローカルにある場合）
.github/secrets/
*.secret
ci-cache/

# =============================================================================
# TypeScript
# =============================================================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# =============================================================================
# その他
# =============================================================================
*.map
.vercel
.netlify

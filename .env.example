# ==========================================
# SuiWalrus Station - 環境設定見本 (.env.example)
# ==========================================
# このファイルを .env にコピーして、自分の値を設定してね！
# GitHub に公開する時は、この .env は絶対にコミットしちゃダメばい！！

# ------------------------------------------
# 🧠 AI 設定 (OpenAI / LLM)
# ------------------------------------------
# OpenAI の API キー
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# (オプション) API のベース URL (Ollama 等を使う場合はここを変更)
# VITE_AI_BASE_URL=https://api.openai.com/v1

# (オプション) 使用するモデル名
# VITE_AI_MODEL=gpt-4o-mini

# ------------------------------------------
# 🛒 Tradeport / Indexer.xyz 設定 (NFT 用)
# ------------------------------------------
# Indexer.xyz の API キー (Tradeport 連携に必須)
VITE_TRADEPORT_API_KEY=your-indexer-xyz-api-key-here

# Indexer.xyz の API ユーザー (UUID形式)
VITE_TRADEPORT_API_USER=your-indexer-xyz-api-user-uuid-here

# ------------------------------------------
# 🛠️ システム設定
# ------------------------------------------
# Sui CLI の絶対パス (Windows の場合はバックスラッシュに注意)
# 例: C:\\Users\\Name\\.sui\\bin\\sui.exe
VITE_SUI_CLI_PATH=sui
